# ── Application mode ─────────────────────────────────────────────
# "web" (default) or "kafka"
APP_MODE=web

# ── Flask ────────────────────────────────────────────────────────
SECRET_KEY=super-secret-key
DEBUG=false

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL example:
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@db-host:5432/customer_mgmt
# SQLite fallback (default):
SQLALCHEMY_DATABASE_URI=sqlite:///customer_management.db

# ── Kafka ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=customer-management-group
KAFKA_TOPIC=purchases
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_POLL_TIMEOUT=1.0

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
# LOG_FILE=/var/log/customer-management.log

